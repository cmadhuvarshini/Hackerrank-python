if __name__ == '__main__':
    records = []
    for _ in range(int(input())):
        name = input()
        score = float(input())
        records.append([name, score])

    scores = set([student[1] for student in records])
    second_lowest_score = sorted(scores)[1]

    result_names = [student[0] for student in records if student[1] == second_lowest_score]
    result_names.sort()

    for name in result_names:
        print(name)
